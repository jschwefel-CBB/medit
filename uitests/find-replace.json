{
  "schemaVersion": "1.1",
  "name": "find-replace: find, next, replace, regex, no-match adversarial",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 100 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },

    { "id": "type-body", "action": "type", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "text": "alpha beta alpha gamma alpha" } },
    { "id": "open-find", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+f" } },
    { "id": "find-field-exists", "action": "assert", "level": "happyPath",
      "target": { "identifier": "findField" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "type-query", "action": "type", "level": "happyPath",
      "target": { "identifier": "findField" },
      "args": { "text": "alpha", "focus": false } },
    { "id": "find-status-exists", "action": "assert", "level": "happyPath",
      "target": { "identifier": "findStatusLabel" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "find-next", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "findField" },
      "args": { "keys": "return" } },
    { "id": "open-replace", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["Find", "Find and Replace…"] } },
    { "id": "replace-field-exists", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "replaceField" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "type-replacement", "action": "type", "level": "integrationSuite",
      "target": { "identifier": "replaceField" },
      "args": { "text": "REPLACED", "focus": false } },
    { "id": "close-find", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "findField" },
      "args": { "keys": "escape" } },
    { "id": "settle-close", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },

    { "id": "open-find-2", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+f" } },
    { "id": "type-no-match", "action": "type", "level": "tryToBreakIt",
      "target": { "identifier": "findField" },
      "args": { "text": "zzz_no_match_zzz", "focus": false } },
    { "id": "status-no-match", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "findStatusLabel" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "escape-find", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "findField" },
      "args": { "keys": "escape" } },

    { "id": "clear-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "delete-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "delete" } },
    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
