{
  "schemaVersion": "1.1",
  "name": "edge: rapid repeated File > New (tab stress)",
  "comment": "Fires File > New many times in quick succession to stress tab creation. tryToBreakIt: medit must stay stable — still exactly one window (⌘N makes tabs, not windows) and a live editor after the burst. Documented primitives only (menu action repeated, assert count / exists). Each new tab is empty, so no save dialog on quit. Requires the Debug build; no fixture.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 150 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-editor", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },

    { "id": "new-1", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-2", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-3", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-4", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-5", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-6", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-7", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "new-8", "action": "menu", "level": "tryToBreakIt", "args": { "menuPath": ["File", "New"] } },
    { "id": "settle-burst", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 2 } },

    { "id": "still-one-window", "action": "assert", "level": "tryToBreakIt",
      "target": { "role": "AXWindow" },
      "assert": { "property": "count", "op": "equals", "expected": "1" } },
    { "id": "editor-alive", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" }, "assert": { "property": "value", "op": "exists" } },
    { "id": "type-responsive", "action": "type", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" }, "args": { "text": "AFTERBURST" } },
    { "id": "settle-type", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "responsive", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "AFTERBURST" } },

    { "id": "clear-a", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "keys": "cmd+a" } },
    { "id": "clear-b", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "keys": "delete" } },
    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
