{
  "schemaVersion": "1.1",
  "name": "preview copy: copy from rendered Markdown preview reaches NSPasteboard",
  "comment": "Regression guard for the v2.7.4 fix: WKWebView's native copy: selector did not reach NSPasteboard.general. The fix intercepts copy: in EditorWindowController, extracts the selection via evaluateJavaScript, and writes directly to NSPasteboard. happyPath: select-all in preview, copy, paste into new tab, assert pasted content. integrationSuite: select partial text, copy, paste into new tab. Requires staged /tmp/medit-ap-copy-test.md (content: '# Hello\nThis is preview copy test content.'). Requires Debug build.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"],
    "launchFiles": ["/tmp/medit-ap-copy-test.md"]
  },
  "defaults": { "timeoutMs": 10000, "retryIntervalMs": 150 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "show-preview", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["View", "Show Markdown Preview"] } },
    { "id": "wait-preview", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "present": true } },
    { "id": "settle-render", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "click-preview", "action": "click", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" } },
    { "id": "select-all", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "cmd+a" } },
    { "id": "copy", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "cmd+c" } },
    { "id": "new-tab", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["File", "New"] } },
    { "id": "wait-new-editor", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "paste", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+v" } },
    { "id": "settle-paste", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "assert-pasted", "action": "assert", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "Hello" } },

    { "id": "open-second-preview-file", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["File", "New"] } },
    { "id": "wait-new-editor-2", "action": "waitFor", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "type-into-new", "action": "type", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "text": "# Second\n\nAnother paragraph for copy test." } },
    { "id": "show-preview-2", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["View", "Show Markdown Preview"] } },
    { "id": "wait-preview-2", "action": "waitFor", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "present": true } },
    { "id": "settle-render-2", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "click-preview-2", "action": "click", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" } },
    { "id": "select-all-preview-2", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "cmd+a" } },
    { "id": "copy-2", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "cmd+c" } },
    { "id": "open-paste-tab", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["File", "New"] } },
    { "id": "wait-paste-editor", "action": "waitFor", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "paste-2", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+v" } },
    { "id": "settle-paste-2", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-paste-2", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "Second" } },

    { "id": "clear-tab3", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "delete-tab3", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "delete" } },
    { "id": "prev-tab-a", "action": "keyPress", "level": "happyPath",
      "target": { "role": "AXWindow" },
      "args": { "keys": "cmd+shift+[" } },
    { "id": "prev-tab-b", "action": "keyPress", "level": "happyPath",
      "target": { "role": "AXWindow" },
      "args": { "keys": "cmd+shift+[" } },
    { "id": "clear-tab1", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "delete-tab1", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "delete" } },
    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
