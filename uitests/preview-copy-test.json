{
  "schemaVersion": "1.1",
  "name": "preview copy: ⌘C in an AUTO-OPENED Markdown preview reaches the pasteboard",
  "comment": "Regression guard for the auto-preview focus bug. showPreview(true) runs from viewDidLoad when autoShowPreviewForMarkdown is on, where view.window is nil — so makeFirstResponder(webView) silently no-opped and the preview never took focus. Select All / ⌘C then went to whatever else held first responder (a Markdown-toolbar button) and copied NOTHING. CRITICAL: this plan must NOT pass --no-auto-preview and must NOT open the preview from the View menu. Both of those enter through the path that always worked and hide the bug — that is exactly why the previous version of this plan passed 33/33 while the app was broken for users. Open a .md file, let auto-preview fire, and copy. Requires staged /tmp/medit-ap-copy-test.md and the Debug build.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"],
    "launchFiles": ["/tmp/medit-ap-copy-test.md"]
  },
  "defaults": { "timeoutMs": 10000, "retryIntervalMs": 150 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },

    { "id": "wait-auto-preview", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "present": true } },
    { "id": "settle-render", "action": "wait", "level": "happyPath", "args": { "seconds": 4 } },

    { "id": "seed-pasteboard", "action": "exec", "level": "happyPath",
      "args": { "command": "printf 'SENTINEL-NOT-OVERWRITTEN' | pbcopy" } },

    { "id": "select-all", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["Edit", "Select All"] } },
    { "id": "settle-select", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "copy", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["Edit", "Copy"] } },
    { "id": "settle-copy", "action": "wait", "level": "happyPath", "args": { "seconds": 2 } },

    { "id": "pasteboard-has-content", "action": "assert", "level": "happyPath",
      "assert": { "property": "clipboard", "op": "contains", "expected": "preview copy test content" } },
    { "id": "pasteboard-not-sentinel", "action": "assert", "level": "happyPath",
      "assert": { "property": "clipboard", "op": "notEquals", "expected": "SENTINEL-NOT-OVERWRITTEN" } },

    { "id": "keystroke-seed", "action": "exec", "level": "integrationSuite",
      "args": { "command": "printf 'SENTINEL-KEYSTROKE' | pbcopy" } },
    { "id": "keystroke-select", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "keys": "cmd+a" } },
    { "id": "keystroke-copy", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "keys": "cmd+c" } },
    { "id": "settle-keystroke", "action": "wait", "level": "integrationSuite", "args": { "seconds": 2 } },
    { "id": "keystroke-copied", "action": "assert", "level": "integrationSuite",
      "assert": { "property": "clipboard", "op": "contains", "expected": "preview copy test content" } },

    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
