{
  "schemaVersion": "1.1",
  "name": "status bar toggles: show/hide status bar, word count, line numbers",
  "comment": "Exercises the View menu toggles for status bar, word count, and line numbers. happyPath: verify status bar elements exist at launch (default on), toggle status bar off then on, assert positionLabel exists after re-enabling. integrationSuite: toggle word count (documentStatsLabel disappears/reappears). tryToBreakIt: rapidly toggle status bar off and on multiple times.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 100 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "type-text", "action": "type", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "text": "hello status bar" } },
    { "id": "assert-position-label", "action": "assert", "level": "happyPath",
      "target": { "identifier": "positionLabel" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "assert-stats-label", "action": "assert", "level": "happyPath",
      "target": { "identifier": "documentStatsLabel" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "hide-status-bar", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["View", "Show Status Bar"] } },
    { "id": "settle-hide", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "show-status-bar", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["View", "Show Status Bar"] } },
    { "id": "settle-show", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "assert-position-back", "action": "assert", "level": "happyPath",
      "target": { "identifier": "positionLabel" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "hide-word-count", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["View", "Show Word Count"] } },
    { "id": "settle-wc-hide", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "show-word-count", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["View", "Show Word Count"] } },
    { "id": "settle-wc-show", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-stats-back", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "documentStatsLabel" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "rapid-toggle-1", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["View", "Show Status Bar"] } },
    { "id": "rapid-toggle-2", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["View", "Show Status Bar"] } },
    { "id": "rapid-toggle-3", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["View", "Show Status Bar"] } },
    { "id": "settle-rapid", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "assert-editor-alive", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "clear-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "delete-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "delete" } },
    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
