{
  "schemaVersion": "1.1",
  "name": "go-to-line: Edit → Go to Line navigates and validates boundary input",
  "comment": "Tests Go to Line sheet (Edit > Go to Line… / cmd+L). happyPath: open sheet via menu, type line 5, press Return, assert positionLabel shows Ln 5. integrationSuite: navigate to the last line of the document. tryToBreakIt: type an out-of-range line number (999999) and assert the caret clamps to last line or sheet closes gracefully (the app must not crash). Requires staged /tmp/medit-ap-long.txt (120 lines).",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchFiles": ["/tmp/medit-ap-long.txt"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 100 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-editor", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "focus-editor", "action": "click", "level": "happyPath",
      "target": { "identifier": "editorTextView" } },
    { "id": "open-goto", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["Edit", "Go to Line…"] } },
    { "id": "wait-goto-field", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "goToLineField" }, "args": { "present": true } },
    { "id": "type-line-5", "action": "type", "level": "happyPath",
      "target": { "identifier": "goToLineField" },
      "args": { "text": "5", "focus": false } },
    { "id": "commit-goto", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "goToLineField" },
      "args": { "keys": "return" } },
    { "id": "settle-goto", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "assert-line-5", "action": "assert", "level": "happyPath",
      "target": { "identifier": "positionLabel" },
      "assert": { "property": "value", "op": "contains", "expected": "Ln 5" } },

    { "id": "open-goto-2", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["Edit", "Go to Line…"] } },
    { "id": "wait-goto-field-2", "action": "waitFor", "level": "integrationSuite",
      "target": { "identifier": "goToLineField" }, "args": { "present": true } },
    { "id": "type-last-line", "action": "type", "level": "integrationSuite",
      "target": { "identifier": "goToLineField" },
      "args": { "text": "100", "focus": false, "clear": true } },
    { "id": "commit-goto-2", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "goToLineField" },
      "args": { "keys": "return" } },
    { "id": "settle-goto-2", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-last-line", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "positionLabel" },
      "assert": { "property": "value", "op": "contains", "expected": "Ln 100" } },

    { "id": "open-goto-3", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["Edit", "Go to Line…"] } },
    { "id": "wait-goto-field-3", "action": "waitFor", "level": "tryToBreakIt",
      "target": { "identifier": "goToLineField" }, "args": { "present": true } },
    { "id": "type-out-of-range", "action": "type", "level": "tryToBreakIt",
      "target": { "identifier": "goToLineField" },
      "args": { "text": "999999", "focus": false, "clear": true } },
    { "id": "commit-goto-3", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "goToLineField" },
      "args": { "keys": "return" } },
    { "id": "settle-goto-3", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "assert-no-crash", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
