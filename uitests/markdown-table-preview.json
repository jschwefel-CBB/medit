{
  "schemaVersion": "1.1",
  "name": "markdown preview renders in the web view",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchFiles": [
      "/tmp/table-test.md"
    ]
  },
  "defaults": {
    "timeoutMs": 8000,
    "retryIntervalMs": 150
  },
  "steps": [
    {
      "id": "wait-window",
      "action": "waitFor",
      "target": {
        "role": "AXWindow"
      },
      "args": {
        "present": true
      },
      "level": "happyPath"
    },
    {
      "id": "show-preview",
      "action": "menu",
      "args": {
        "menuPath": [
          "View",
          "Show Markdown Preview"
        ]
      },
      "level": "happyPath"
    },
    {
      "id": "wait-preview",
      "action": "waitFor",
      "target": {
        "identifier": "markdownPreviewWebView"
      },
      "args": {
        "present": true
      },
      "level": "happyPath"
    },
    {
      "id": "shot-preview",
      "action": "screenshot",
      "target": {
        "identifier": "markdownPreviewWebView"
      },
      "args": {
        "path": "/tmp/apshots/table-preview.png",
        "padding": 0
      },
      "level": "happyPath"
    }
  ]
}
