{
  "schemaVersion": "1.1",
  "name": "settings: every checkbox toggles and every popup selects each value",
  "comment": "Exercises every Settings CHECKBOX exhaustively. happyPath: open Settings (cmd+,), read a control's default, toggle it, assert the value flipped. integrationSuite: toggle every remaining checkbox and assert each flip. Each control is targeted by its stable settings.* identifier. Checkbox AXValue is '1'/'0'. The three Settings POPUPS are covered by dedicated one-popup-per-run plans (settings-popup-*.json) because AutoPilot cannot reliably open a second NSPopUpButton in the same session \u2014 see docs/autopilot-feedback.md. Requires the Debug build. No fixture; toggling only flips prefs (no unsaved document) so no pre-quit cleanup is needed.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": [
      "--reset-state"
    ]
  },
  "defaults": {
    "timeoutMs": 8000,
    "retryIntervalMs": 150
  },
  "steps": [
    {
      "id": "wait-window",
      "action": "waitFor",
      "level": "happyPath",
      "target": {
        "role": "AXWindow"
      },
      "args": {
        "present": true
      }
    },
    {
      "id": "wait-editor",
      "action": "waitFor",
      "level": "happyPath",
      "target": {
        "identifier": "editorTextView"
      },
      "args": {
        "present": true
      }
    },
    {
      "id": "open-settings",
      "action": "keyPress",
      "level": "happyPath",
      "target": {
        "identifier": "editorTextView"
      },
      "args": {
        "keys": "cmd+,"
      }
    },
    {
      "id": "wait-settings",
      "action": "waitFor",
      "level": "happyPath",
      "target": {
        "identifier": "settings.showLineNumbers"
      },
      "args": {
        "present": true
      }
    },
    {
      "id": "lineNumbers-default-on",
      "action": "assert",
      "level": "happyPath",
      "target": {
        "identifier": "settings.showLineNumbers"
      },
      "assert": {
        "property": "value",
        "op": "equals",
        "expected": "1"
      }
    },
    {
      "id": "lineNumbers-toggle",
      "action": "press",
      "level": "happyPath",
      "target": {
        "identifier": "settings.showLineNumbers"
      }
    },
    {
      "id": "lineNumbers-now-off",
      "action": "assert",
      "level": "happyPath",
      "target": {
        "identifier": "settings.showLineNumbers"
      },
      "assert": {
        "property": "value",
        "op": "equals",
        "expected": "0"
      }
    },
    {
