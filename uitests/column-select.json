{
  "schemaVersion": "1.1",
  "name": "text transforms and column selection mode",
  "comment": "Tests Edit > Text menu transforms plus Column Selection Mode. Column mode is NOT reachable via the menu action (the item is disabled at menu-open time — see docs/autopilot-feedback.md), but it HAS a key equivalent (Option-Command-B), so it is driven via keyPress and asserted through the columnModeLabel status element (shows 'BLK' when on). happyPath: type multiline text, select all, make upper case (assert 'ALPHA'), make lower case (assert 'alpha'). integrationSuite: Capitalize, then sort ascending/descending, assert content survives; toggle column mode on via cmd+opt+b and assert columnModeLabel shows BLK, toggle off. tryToBreakIt: sort twice in a row, assert no crash. Documented primitives only.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchArgs": ["--reset-state"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 100 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-editor", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "type-multiline", "action": "type", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "text": "alpha\nbeta\ngamma" } },
    { "id": "select-all", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "make-upper", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["Edit", "Text", "Make Upper Case"] } },
    { "id": "assert-upper", "action": "assert", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "ALPHA" } },
    { "id": "make-lower", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["Edit", "Text", "Make Lower Case"] } },
    { "id": "assert-lower", "action": "assert", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "alpha" } },

    { "id": "select-all-2", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "sort-asc", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["Edit", "Text", "Sort Lines Ascending"] } },
    { "id": "settle-sort", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-sorted-exists", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },
    { "id": "select-all-3", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "sort-desc", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["Edit", "Text", "Sort Lines Descending"] } },
    { "id": "settle-desc", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-desc-exists", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "select-all-cap", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" }, "args": { "keys": "cmd+a" } },
    { "id": "capitalize", "action": "menu", "level": "integrationSuite",
      "args": { "menuPath": ["Edit", "Text", "Capitalize"] } },
    { "id": "settle-cap", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "assert-cap-exists", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "column-mode-on", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" }, "args": { "keys": "cmd+opt+b" } },
    { "id": "settle-colmode-on", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "colmode-label-blk", "action": "assert", "level": "integrationSuite",
      "target": { "identifier": "columnModeLabel" },
      "assert": { "property": "value", "op": "contains", "expected": "BLK" } },
    { "id": "column-mode-off", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" }, "args": { "keys": "cmd+opt+b" } },
    { "id": "settle-colmode-off", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },

    { "id": "select-all-4", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "sort-asc-1", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["Edit", "Text", "Sort Lines Ascending"] } },
    { "id": "sort-asc-2", "action": "menu", "level": "tryToBreakIt",
      "args": { "menuPath": ["Edit", "Text", "Sort Lines Ascending"] } },
    { "id": "settle-double", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "assert-alive", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "exists" } },

    { "id": "clear-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+a" } },
    { "id": "delete-before-quit", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "delete" } },
    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
