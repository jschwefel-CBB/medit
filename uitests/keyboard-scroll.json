{
  "schemaVersion": "1.1",
  "name": "editor caret scroll: End to bottom, Home to top, Page Down/Up",
  "comment": "Regression for the 2.6.x editor scroll-to-caret bug. Drives the caret to the document end with cmd+down, captures the bottom-of-file view, then returns to the top with cmd+up. integrationSuite adds page-down/page-up. tryToBreakIt ensures Home after End does not leave caret in a broken state. Requires staged /tmp/medit-ap-long.txt fixture.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchFiles": ["/tmp/medit-ap-long.txt"]
  },
  "defaults": { "timeoutMs": 8000, "retryIntervalMs": 150 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-editor", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "editorTextView" }, "args": { "present": true } },
    { "id": "editor-loaded", "action": "assert", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "assert": { "property": "value", "op": "contains", "expected": "Line 120 of the scroll fixture." } },
    { "id": "focus-editor", "action": "click", "level": "happyPath",
      "target": { "identifier": "editorTextView" } },
    { "id": "caret-to-end", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+down" } },
    { "id": "settle-end", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "shot-bottom", "action": "screenshot", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "padding": 0 } },
    { "id": "press-return", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "return" } },
    { "id": "settle-return", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "shot-after-return", "action": "screenshot", "level": "happyPath",
      "target": { "identifier": "editorTextView" },
      "args": { "padding": 0 } },

    { "id": "caret-to-start", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+up" } },
    { "id": "settle-top", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "shot-top", "action": "screenshot", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "padding": 0 } },
    { "id": "page-down", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "pagedown" } },
    { "id": "settle-pagedown", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "page-up", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "pageup" } },
    { "id": "settle-pageup", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },

    { "id": "home-from-end", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+down" } },
    { "id": "settle-end2", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "home-again", "action": "keyPress", "level": "tryToBreakIt",
      "target": { "identifier": "editorTextView" },
      "args": { "keys": "cmd+up" } },
    { "id": "settle-home2", "action": "wait", "level": "tryToBreakIt", "args": { "seconds": 1 } },
    { "id": "status-after-home", "action": "assert", "level": "tryToBreakIt",
      "target": { "identifier": "positionLabel" },
      "assert": { "property": "value", "op": "contains", "expected": "Ln 1" } },

    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
