{
  "schemaVersion": "1.1",
  "name": "Markdown preview keyboard scroll: End to bottom, Home back to top",
  "comment": "Regression for the 2.6.x preview keyboard-scroll bug: navigation keys did nothing in the WKWebView preview because it never took first responder and content JS was disabled. Opens a long Markdown file, shows the preview, focuses it, presses End, captures before/after. integrationSuite adds Home to verify scrolling back up. NOTE: element-scoped WKWebView screenshots require medit to be frontmost during capture (WebKit/ScreenCaptureKit limitation). Requires staged /tmp/medit-ap-long.md fixture.",
  "target": {
    "path": "/Volumes/Scratch/Xcode/DerivedData/Debug/medit.app",
    "launchFiles": ["/tmp/medit-ap-long.md"]
  },
  "defaults": { "timeoutMs": 10000, "retryIntervalMs": 150 },
  "steps": [
    { "id": "wait-window", "action": "waitFor", "level": "happyPath",
      "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "focus-editor", "action": "click", "level": "happyPath",
      "target": { "identifier": "editorTextView" } },
    { "id": "show-preview", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["View", "Show Markdown Preview"] } },
    { "id": "wait-preview", "action": "waitFor", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" }, "args": { "present": true } },
    { "id": "shot-top", "action": "screenshot", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "padding": 0 } },
    { "id": "focus-preview", "action": "click", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" } },
    { "id": "press-end", "action": "keyPress", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "end" } },
    { "id": "settle-end", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },
    { "id": "shot-bottom", "action": "screenshot", "level": "happyPath",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "padding": 0 } },

    { "id": "press-home", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "home" } },
    { "id": "settle-home", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "shot-top-again", "action": "screenshot", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "padding": 0 } },
    { "id": "pagedown-preview", "action": "keyPress", "level": "integrationSuite",
      "target": { "identifier": "markdownPreviewWebView" },
      "args": { "keys": "pagedown" } },
    { "id": "settle-pd", "action": "wait", "level": "integrationSuite", "args": { "seconds": 1 } },
    { "id": "hide-preview", "action": "menu", "level": "happyPath",
      "args": { "menuPath": ["View", "Show Markdown Preview"] } },
    { "id": "settle-hide", "action": "wait", "level": "happyPath", "args": { "seconds": 1 } },

    { "id": "quit", "action": "terminate", "level": "happyPath" }
  ]
}
