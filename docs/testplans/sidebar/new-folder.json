{
  "schemaVersion": "1.0",
  "name": "sidebar: New Folder creates untitled folder inside, enters rename, and commits the name",
  "target": {
    "bundleId": "com.jschwefel.medit",
    "launchArgs": ["--reset-state", "--open-folder", "/tmp/medit-fixture"]
  },
  "defaults": { "timeoutMs": 6000, "retryIntervalMs": 100 },
  "comment": "PRECONDITION: `rm -rf /tmp/medit-fixture && mkdir -p /tmp/medit-fixture`. Verifies the 1.5 fix: New Folder creates 'untitled folder' INSIDE the right-clicked folder, enters rename, and commits. keyPress per char (no click) into the pre-focused rename field, then Return to commit.",
  "steps": [
    { "id": "wait-window", "action": "waitFor", "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-outline", "action": "waitFor", "target": { "identifier": "sidebarOutline" }, "args": { "present": true } },
    { "id": "right-click-root-folder", "action": "rightClick", "target": { "role": "AXStaticText", "value": "medit-fixture" } },
    { "id": "click-new-folder", "action": "click", "target": { "role": "AXMenuItem", "title": "New Folder" } },
    { "id": "wait-rename-field", "action": "waitFor", "target": { "role": "AXTextField", "value": "untitled folder" }, "args": { "present": true } },
    { "id": "k-s", "action": "keyPress", "target": { "role": "AXTextField", "value": "untitled folder" }, "args": { "keys": "s" } },
    { "id": "k-r", "action": "keyPress", "target": { "role": "AXTextField", "value": "s" }, "args": { "keys": "r" } },
    { "id": "k-c", "action": "keyPress", "target": { "role": "AXTextField", "value": "sr" }, "args": { "keys": "c" } },
    { "id": "commit", "action": "keyPress", "target": { "role": "AXTextField", "value": "src" }, "args": { "keys": "return" } },
    { "id": "assert-folder-row", "action": "assert", "target": { "role": "AXStaticText", "value": "src" }, "assert": { "property": "exists", "op": "exists", "expected": "true" } },
    { "id": "assert-untitled-gone", "action": "assert", "target": { "role": "AXStaticText", "value": "untitled folder" }, "assert": { "property": "exists", "op": "notExists", "expected": "true" } },
    { "id": "quit", "action": "terminate" }
  ]
}
