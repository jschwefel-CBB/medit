{
  "schemaVersion": "1.0",
  "name": "sidebar: New File creates untitled, enters rename, and commits the new name",
  "target": {
    "bundleId": "com.jschwefel.medit",
    "launchArgs": ["--reset-state", "--open-folder", "/tmp/medit-fixture"]
  },
  "defaults": { "timeoutMs": 6000, "retryIntervalMs": 100 },
  "comment": "PRECONDITION: `rm -rf /tmp/medit-fixture && mkdir -p /tmp/medit-fixture`. Verifies the full 1.5 flow: New File creates 'untitled' inside the clicked folder, enters an inline rename field (pre-focused with its text selected), and the rename COMMITS to the new name. The rename field is first-responder on open, so we keyPress each character (no click — autopilot's `type` focus-click drops a pre-focused field's editor, like the find field) and keyPress Return to fire end-editing. Asserts the new row appears and the old 'untitled' name is gone.",
  "steps": [
    { "id": "wait-window", "action": "waitFor", "target": { "role": "AXWindow" }, "args": { "present": true } },
    { "id": "wait-outline", "action": "waitFor", "target": { "identifier": "sidebarOutline" }, "args": { "present": true } },
    { "id": "right-click-root-folder", "action": "rightClick", "target": { "role": "AXStaticText", "value": "medit-fixture" } },
    { "id": "click-new-file", "action": "click", "target": { "role": "AXMenuItem", "title": "New File" } },
    { "id": "wait-rename-field", "action": "waitFor", "target": { "role": "AXTextField", "value": "untitled" }, "args": { "present": true } },
    { "id": "k-n", "action": "keyPress", "target": { "role": "AXTextField", "value": "untitled" }, "args": { "keys": "n" } },
    { "id": "k-o", "action": "keyPress", "target": { "role": "AXTextField", "value": "n" }, "args": { "keys": "o" } },
    { "id": "k-t", "action": "keyPress", "target": { "role": "AXTextField", "value": "no" }, "args": { "keys": "t" } },
    { "id": "k-e", "action": "keyPress", "target": { "role": "AXTextField", "value": "not" }, "args": { "keys": "e" } },
    { "id": "k-s", "action": "keyPress", "target": { "role": "AXTextField", "value": "note" }, "args": { "keys": "s" } },
    { "id": "commit", "action": "keyPress", "target": { "role": "AXTextField", "value": "notes" }, "args": { "keys": "return" } },
    { "id": "assert-renamed-row", "action": "assert", "target": { "role": "AXStaticText", "value": "notes" }, "assert": { "property": "exists", "op": "exists", "expected": "true" } },
    { "id": "assert-untitled-gone", "action": "assert", "target": { "role": "AXStaticText", "value": "untitled" }, "assert": { "property": "exists", "op": "notExists", "expected": "true" } },
    { "id": "quit", "action": "terminate" }
  ]
}
